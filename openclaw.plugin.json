{
  "id": "clawtalk",
  "name": "ClawTalk",
  "description": "Voice calls, SMS, missions, and approvals via ClawTalk",
  "skills": ["./skills"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "required": [],
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "apiKey": {
        "type": "string",
        "description": "ClawTalk API key"
      },
      "server": {
        "type": "string",
        "description": "ClawTalk server URL",
        "default": "https://clawdtalk.com"
      },
      "ownerName": {
        "type": "string",
        "description": "User's name for voice greeting"
      },
      "agentName": {
        "type": "string",
        "description": "Agent's name for voice context"
      },
      "greeting": {
        "type": "string",
        "description": "Custom greeting for inbound calls"
      },
      "agentId": {
        "type": "string",
        "description": "Gateway agent ID",
        "default": "main"
      },
      "autoConnect": {
        "type": "boolean",
        "description": "Connect WebSocket on startup",
        "default": true
      },
      "voiceContext": {
        "type": "string",
        "description": "Override default voice context prompt"
      },
      "missions": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "defaultVoice": {
            "type": "string",
            "description": "Default TTS voice for mission assistants"
          },
          "defaultModel": {
            "type": "string",
            "description": "Default AI model for mission assistants"
          },
          "observer": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "enabled": {
                "type": "boolean",
                "default": true
              },
              "intervalMs": {
                "type": "number",
                "description": "Mission observer interval (ms)",
                "default": 300000
              },
              "staleThresholdMs": {
                "type": "number",
                "description": "Mission stale threshold (ms)",
                "default": 7200000
              },
              "cooldowns": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "pendingCallsMs": {
                    "type": "number",
                    "description": "Cooldown between pending-call nudges (ms)",
                    "default": 900000
                  },
                  "staleMs": {
                    "type": "number",
                    "description": "Cooldown between stale-mission nudges (ms)",
                    "default": 3600000
                  },
                  "terminalPlanMs": {
                    "type": "number",
                    "description": "Cooldown between terminal-plan nudges (ms)",
                    "default": 3600000
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "uiHints": {
    "apiKey": {
      "label": "API Key",
      "sensitive": true
    },
    "server": {
      "label": "Server URL",
      "placeholder": "https://clawdtalk.com",
      "advanced": true
    },
    "ownerName": {
      "label": "Your Name"
    },
    "agentName": {
      "label": "Agent Name"
    },
    "greeting": {
      "label": "Greeting",
      "advanced": true
    },
    "agentId": {
      "label": "Agent ID",
      "advanced": true
    },
    "autoConnect": {
      "label": "Auto-Connect WebSocket",
      "advanced": true
    },
    "voiceContext": {
      "label": "Voice Context Prompt",
      "advanced": true
    },
    "missions.enabled": {
      "label": "Enable Missions"
    },
    "missions.defaultVoice": {
      "label": "Default Voice",
      "advanced": true
    },
    "missions.defaultModel": {
      "label": "Default Model",
      "advanced": true
    },
    "missions.observer.enabled": {
      "label": "Enable Mission Observer",
      "advanced": true
    },
    "missions.observer.intervalMs": {
      "label": "Mission Observer Interval (ms)",
      "advanced": true
    },
    "missions.observer.staleThresholdMs": {
      "label": "Mission Stale Threshold (ms)",
      "advanced": true
    },
    "missions.observer.cooldowns.pendingCallsMs": {
      "label": "Pending Call Cooldown (ms)",
      "advanced": true
    },
    "missions.observer.cooldowns.staleMs": {
      "label": "Stale Mission Cooldown (ms)",
      "advanced": true
    },
    "missions.observer.cooldowns.terminalPlanMs": {
      "label": "Terminal Plan Cooldown (ms)",
      "advanced": true
    }
  }
}
